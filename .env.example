# Required GitHub Actions secrets for this repository
#
# Configure these in: https://github.com/tesslio/good-oss-citizen/settings/secrets/actions
#
# Used by .github/workflows/review-openai.lock.yml and review-anthropic.lock.yml
# (the gh-aw paired PR policy reviewers from jbaruch/coding-policy@v0.1.20).

# OpenAI Codex engine — used by review-openai workflow when reviewing PRs from
# claude-family authors (cross-family review per rules/author-model-declaration.md).
# Value: an OpenAI API key with billing access for the gpt-5.x family.
OPENAI_API_KEY=

# Anthropic Claude Code engine — used by review-anthropic workflow when reviewing
# PRs from openai-family authors (cross-family review per rules/author-model-declaration.md).
# Value: an Anthropic API key with billing access for the claude-opus-4-x family.
ANTHROPIC_API_KEY=

# Tessl registry token — used by tessl install jbaruch/coding-policy in the
# pre-agent-steps of both review workflows so each run pulls the latest published
# coding-policy rules instead of bleeding from main.
# Generate at: https://tessl.io/account/api-keys
TESSL_TOKEN=
